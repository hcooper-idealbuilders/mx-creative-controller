{
  "_comment": "Merge the 'hooks' block into ~/.claude/settings.json. Uses forward slashes so the path survives shell quoting.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File C:/Users/hdcooper/Hardware-interface/hooks/update-status.ps1 -Event SessionStart"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File C:/Users/hdcooper/Hardware-interface/hooks/update-status.ps1 -Event UserPromptSubmit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File C:/Users/hdcooper/Hardware-interface/hooks/update-status.ps1 -Event Stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File C:/Users/hdcooper/Hardware-interface/hooks/update-status.ps1 -Event Notification"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File C:/Users/hdcooper/Hardware-interface/hooks/update-status.ps1 -Event SessionEnd"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Read|Write|Glob|Grep|WebFetch|WebSearch|TaskCreate|TaskUpdate|TaskList",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File C:/Users/hdcooper/Hardware-interface/hooks/update-status.ps1 -Event PreToolUse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Read|Write|Glob|Grep|WebFetch|WebSearch|TaskCreate|TaskUpdate|TaskList",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File C:/Users/hdcooper/Hardware-interface/hooks/update-status.ps1 -Event PostToolUse"
          }
        ]
      }
    ]
  }
}
